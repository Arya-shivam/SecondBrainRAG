{
  "manifest_version": 3,
  "name": "Dhi - Second Brain",
  "version": "1.1",
  "description": "Send links to your Second Brain and chat with Dhi.",
  "permissions": [
    "activeTab",
    "tabs",
    "contextMenus",
    "notifications",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Chat with Dhi"
  }
}
