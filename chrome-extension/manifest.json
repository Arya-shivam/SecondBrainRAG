{
  "manifest_version": 3,
  "name": "Dhi - Second Brain Capture",
  "version": "1.0",
  "description": "Send links and articles instantly to your local Dhi RAG system.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Send to Dhi"
  }
}
